# Environment
ENVIRONMENT=developement
DEBUG=True

# API Configuration
API_V1_STR=/api/v1
PROJECT_NAME=github_crawler
PROJECT_DESCRIPTION=Github Crawler using Github Graphql API

# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgrespassword
POSTGRES_DB=github_crawler
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}
SYNC_DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}

# CORS
BACKEND_CORS_ORIGINS=["https://example.com", "https://www.example.com"]

# Github Token and Endpoint
GITHUB_TOKEN=GithubTokenHere-if-running-locally
GITHUB_ENDPOINT=https://api.github.com/graphql
